{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "pendelgeist-com",
  "compatibility_date": "2025-09-27",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "./public"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "routes": [
    {
      "pattern": "pendelgeist.com",
      "custom_domain": true
    },
    {
      "pattern": "www.pendelgeist.com",
      "custom_domain": true
    }
  ]
}
